  const tabIndex = ['roster','stats','schedule','videos','photos','sponsors'];
  document.querySelectorAll('.tab')[tabIndex.indexOf(tab)].classList.add('active');
  document.getElementById(`sec-${tab}`).classList.add('active');

  window.scrollTo({ top: 300, behavior: 'smooth' });
}

// ── TABLE SORT ──
let sortDir = {};
function sortTable(col) {
  sortDir[col] = !sortDir[col];
  const data = [...statsData].sort((a, b) => {
    const vals = [a.name, a.pos, a.g, a.ab, a.h, a.dbl, a.trp, a.hr, a.rbi, a.r, a.sb, parseFloat(a.avg), parseFloat(a.obp)];
    const valsb = [b.name, b.pos, b.g, b.ab, b.h, b.dbl, b.trp, b.hr, b.rbi, b.r, b.sb, parseFloat(b.avg), parseFloat(b.obp)];
    if (typeof vals[col] === 'string') return sortDir[col] ? vals[col].localeCompare(valsb[col]) : valsb[col].localeCompare(vals[col]);
    return sortDir[col] ? vals[col] - valsb[col] : valsb[col] - vals[col];
  });
  const tbody = document.getElementById('stats-body');
  const maxAvg = Math.max(...data.map(p => parseFloat(p.avg)));
